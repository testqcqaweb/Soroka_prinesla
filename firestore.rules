rules_version = '2';

// ===============================================================
// Assumed Data Model (Santa Prod. Phase 1)
// ===============================================================
//
// projects/{projectId}
//   owner_id, title, type, status, logline, script_id, created_at, updated_at
//
// scripts/{scriptId}
//   project_id, title, current_version_id, created_at
//
// scripts/{scriptId}/versions/{versionId}
//   script_id, version_number, label, note, created_at, created_by, blocks[]
//
// blocks item: { id, sort_order, type, content, scene_number }

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidProject() {
      let data = request.resource.data;
      return data.keys().hasAll(['owner_id', 'title', 'type', 'status', 'created_at', 'updated_at'])
        && data.owner_id is string
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.type in ['feature', 'short', 'series', 'pilot', 'other']
        && data.status in ['development', 'pre_production', 'production', 'archived']
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && (!('logline' in data) || data.logline == null || data.logline is string)
        && (!('script_id' in data) || data.script_id is string);
    }

    function isValidScript() {
      let data = request.resource.data;
      return data.keys().hasAll(['project_id', 'title', 'created_at'])
        && data.project_id is string
        && data.title is string
        && data.created_at is timestamp
        && (!('current_version_id' in data) || data.current_version_id is string);
    }

    function isValidVersion() {
      let data = request.resource.data;
      return data.keys().hasAll(['script_id', 'version_number', 'created_at', 'created_by', 'blocks'])
        && data.script_id is string
        && data.version_number is int
        && data.version_number > 0
        && data.created_at is timestamp
        && data.created_by is string
        && data.blocks is list
        && (!('label' in data) || data.label == null || data.label is string)
        && (!('note' in data) || data.note == null || data.note is string);
    }

    match /projects/{projectId} {
      allow read: if isOwner(resource.data.owner_id);
      allow create: if isSignedIn()
        && request.resource.data.owner_id == request.auth.uid
        && isValidProject();
      allow update: if isOwner(resource.data.owner_id)
        && request.resource.data.owner_id == resource.data.owner_id
        && isValidProject();
      allow delete: if isOwner(resource.data.owner_id);
    }

    match /scripts/{scriptId} {
      allow read: if isSignedIn()
        && isOwner(get(/databases/$(database)/documents/projects/$(resource.data.project_id)).data.owner_id);
      allow create: if isSignedIn()
        && isOwner(get(/databases/$(database)/documents/projects/$(request.resource.data.project_id)).data.owner_id)
        && isValidScript();
      allow update: if isSignedIn()
        && isOwner(get(/databases/$(database)/documents/projects/$(resource.data.project_id)).data.owner_id)
        && request.resource.data.project_id == resource.data.project_id
        && isValidScript();
      allow delete: if isSignedIn()
        && isOwner(get(/databases/$(database)/documents/projects/$(resource.data.project_id)).data.owner_id);

      match /versions/{versionId} {
        allow read: if isSignedIn()
          && isOwner(get(/databases/$(database)/documents/projects/$(get(/databases/$(database)/documents/scripts/$(scriptId)).data.project_id)).data.owner_id);
        allow create: if isSignedIn()
          && isOwner(get(/databases/$(database)/documents/projects/$(get(/databases/$(database)/documents/scripts/$(scriptId)).data.project_id)).data.owner_id)
          && request.resource.data.created_by == request.auth.uid
          && isValidVersion();
        allow update: if isSignedIn()
          && isOwner(get(/databases/$(database)/documents/projects/$(get(/databases/$(database)/documents/scripts/$(scriptId)).data.project_id)).data.owner_id)
          && request.resource.data.script_id == resource.data.script_id
          && request.resource.data.created_by == resource.data.created_by
          && isValidVersion();
        allow delete: if isSignedIn()
          && isOwner(get(/databases/$(database)/documents/projects/$(get(/databases/$(database)/documents/scripts/$(scriptId)).data.project_id)).data.owner_id);
      }
    }
  }
}
