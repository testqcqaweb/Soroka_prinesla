rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function projectOwner(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.owner_id;
    }

    function ownsProject(projectId) {
      return isOwner(projectOwner(projectId));
    }

    function isValidProject() {
      let data = request.resource.data;
      return data.keys().hasAll(['owner_id', 'title', 'type', 'status', 'created_at', 'updated_at'])
        && data.owner_id is string
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.type in ['feature', 'short', 'series', 'pilot', 'other']
        && data.status in ['development', 'pre_production', 'production', 'archived']
        && data.created_at is timestamp
        && data.updated_at is timestamp;
    }

    function isValidScript() {
      let data = request.resource.data;
      return data.keys().hasAll(['project_id', 'title', 'created_at'])
        && data.project_id is string
        && data.title is string
        && data.created_at is timestamp;
    }

    function isValidVersion() {
      let data = request.resource.data;
      return data.keys().hasAll(['script_id', 'version_number', 'created_at', 'created_by', 'blocks'])
        && data.script_id is string
        && data.version_number is int
        && data.version_number > 0
        && data.created_at is timestamp
        && data.created_by is string
        && data.blocks is list;
    }

    function isValidTask() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'status', 'priority', 'created_at'])
        && data.title is string
        && data.title.size() > 0
        && data.status in ['todo', 'in_progress', 'done']
        && data.priority in ['low', 'medium', 'high']
        && data.created_at is timestamp;
    }

    function isValidCalendarEvent() {
      let data = request.resource.data;
      return data.keys().hasAll(['owner_id', 'title', 'type', 'start_at', 'created_at'])
        && data.owner_id is string
        && data.title is string
        && data.type in ['deadline', 'meeting', 'milestone', 'other']
        && data.start_at is timestamp
        && data.created_at is timestamp;
    }

    match /projects/{projectId} {
      allow read: if ownsProject(projectId);
      allow create: if isSignedIn()
        && request.resource.data.owner_id == request.auth.uid
        && isValidProject();
      allow update: if ownsProject(projectId)
        && request.resource.data.owner_id == resource.data.owner_id
        && isValidProject();
      allow delete: if ownsProject(projectId);

      match /tasks/{taskId} {
        allow read, write: if ownsProject(projectId);
        allow create: if ownsProject(projectId) && isValidTask();
        allow update: if ownsProject(projectId) && isValidTask();
      }

      match /characters/{characterId} {
        allow read, write: if ownsProject(projectId);
      }

      match /beats/{beatId} {
        allow read, write: if ownsProject(projectId);
      }

      match /development/{docId} {
        allow read, write: if ownsProject(projectId);
      }
    }

    match /scripts/{scriptId} {
      allow read: if isSignedIn()
        && ownsProject(resource.data.project_id);
      allow create: if isSignedIn()
        && ownsProject(request.resource.data.project_id)
        && isValidScript();
      allow update: if isSignedIn()
        && ownsProject(resource.data.project_id)
        && request.resource.data.project_id == resource.data.project_id
        && isValidScript();
      allow delete: if isSignedIn()
        && ownsProject(resource.data.project_id);

      match /versions/{versionId} {
        allow read, write: if isSignedIn()
          && ownsProject(get(/databases/$(database)/documents/scripts/$(scriptId)).data.project_id);
        allow create: if isSignedIn()
          && ownsProject(get(/databases/$(database)/documents/scripts/$(scriptId)).data.project_id)
          && request.resource.data.created_by == request.auth.uid
          && isValidVersion();
        allow update: if isSignedIn()
          && ownsProject(get(/databases/$(database)/documents/scripts/$(scriptId)).data.project_id)
          && isValidVersion();
      }
    }

    match /calendar_events/{eventId} {
      allow read: if isOwner(resource.data.owner_id);
      allow create: if isSignedIn()
        && request.resource.data.owner_id == request.auth.uid
        && isValidCalendarEvent();
      allow update: if isOwner(resource.data.owner_id)
        && request.resource.data.owner_id == resource.data.owner_id
        && isValidCalendarEvent();
      allow delete: if isOwner(resource.data.owner_id);
    }
  }
}
